# Copy this file to .env and fill in your values
# The app reads these at startup via python-dotenv (or set them as OS env vars)

# CSFloat API key — get yours at https://csfloat.com/profile (Developer tab)
CSFLOAT_API_KEY=

# SteamWebAPI — https://www.steamwebapi.com
# Free tier rate limits:
#   Inventory: 2 req/min · 5 req/day · 5 req/month  ← very precious!
#   Global:    2 req/min · 5 req/day · 10 req/month
#   Items:     0 / 0 / 0 (no access on free tier)
#   Assets:    5 / 5 / 5
# Only call POST /inventory/sync on explicit user action — never auto-refresh.
steamwebapi_key=
steam_id=
